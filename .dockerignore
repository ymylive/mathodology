# Build artifacts
target/
**/node_modules/
**/.venv/
**/dist/
**/__pycache__/
**/*.pyc

# Host-only cargo config (linker tweaks, jobs count). Inside the build
# container we want the defaults — fewer surprises, smaller invalidation
# surface for the cargo-chef recipe.
.cargo/

# Local data
runs/
docker-data/
dump.rdb
*.db
*.sqlite*

# Env / secrets
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.idea/
.vscode/
*.log

# VCS
.git/
.gitignore
