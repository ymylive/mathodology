# Copy to .env and fill in values. .env is git-ignored.

# --- Gateway ---
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8080
DEV_AUTH_TOKEN=dev-local-insecure-token

# --- Infra ---
REDIS_URL=redis://127.0.0.1:6379/0
DATABASE_URL=postgres://mm:mm@127.0.0.1:5432/mm

# --- Run artifacts ---
# Filesystem root that the Python worker writes into (figures, notebook.ipynb)
# and the gateway serves over /runs/:run_id/figures/* and /runs/:run_id/notebook.
RUNS_DIR=./runs

# --- LLM providers (optional in M1) ---
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Worker → Gateway ---
GATEWAY_HTTP=http://127.0.0.1:8080
WORKER_CONCURRENCY=2

# HMML retrieval knobs (M11). Set HMML_VECTOR=0 to force BM25-only.
HMML_VECTOR=1

# --- open-webSearch MCP (Searcher auxiliary retrieval, M12) ---
# `open-websearch` is a Node CLI (install globally: `npm i -g open-websearch`)
# that speaks MCP over stdio and proxies queries through Bing/Baidu/DuckDuckGo/
# CSDN/Juejin/Brave/Exa/Startpage. The Searcher runs it in parallel with arXiv
# and merges results. Set OPEN_WEBSEARCH_DISABLED=1 to fall back to arXiv only.
OPEN_WEBSEARCH_CMD=open-websearch
OPEN_WEBSEARCH_ENGINES=bing,duckduckgo,baidu,csdn,juejin
OPEN_WEBSEARCH_DISABLED=0

# --- Frontend ---
VITE_GATEWAY_HTTP=http://127.0.0.1:8080
VITE_GATEWAY_WS=ws://127.0.0.1:8080
VITE_DEV_AUTH_TOKEN=dev-local-insecure-token

# --- Logging ---
RUST_LOG=gateway=debug,tower_http=info,info
PYTHONUNBUFFERED=1
