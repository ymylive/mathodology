# Copy to .env and fill in values. .env is git-ignored.

# --- Gateway ---
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8080
DEV_AUTH_TOKEN=dev-local-insecure-token

# --- Infra ---
REDIS_URL=redis://127.0.0.1:6379/0
DATABASE_URL=postgres://mm:mm@127.0.0.1:5432/mm

# --- LLM providers (optional in M1) ---
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Worker → Gateway ---
GATEWAY_HTTP=http://127.0.0.1:8080
WORKER_CONCURRENCY=2

# --- Frontend ---
VITE_GATEWAY_HTTP=http://127.0.0.1:8080
VITE_GATEWAY_WS=ws://127.0.0.1:8080
VITE_DEV_AUTH_TOKEN=dev-local-insecure-token

# --- Logging ---
RUST_LOG=gateway=debug,tower_http=info,info
PYTHONUNBUFFERED=1
